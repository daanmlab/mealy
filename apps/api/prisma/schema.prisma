generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum FoodGoal {
  easy
  healthy
  cheap
  high_protein
}

enum CookTimePreference {
  under20
  under40
  any
}

enum PlanStatus {
  draft
  confirmed
}

enum DayOfWeek {
  monday
  tuesday
  wednesday
  thursday
  friday
  saturday
  sunday
}

enum UnitType {
  weight
  volume
  count
  other
}

// ─── Lookup / catalogue tables ────────────────────────────────────────────────

model Unit {
  id     String   @id @default(cuid())
  symbol String   @unique
  name   String
  type   UnitType

  conversionsFrom        UnitConversion[]        @relation("FromUnit")
  conversionsTo          UnitConversion[]        @relation("ToUnit")
  recipeIngredients      RecipeIngredient[]
  groceryListItems       GroceryListItem[]
  groceryListItemSources GroceryListItemSource[]

  @@map("units")
}

model UnitConversion {
  id         String @id @default(cuid())
  fromUnitId String
  toUnitId   String
  /// Multiply fromUnit amount by this factor to get toUnit amount
  factor     Float

  fromUnit Unit @relation("FromUnit", fields: [fromUnitId], references: [id])
  toUnit   Unit @relation("ToUnit",   fields: [toUnitId],   references: [id])

  @@unique([fromUnitId, toUnitId])
  @@map("unit_conversions")
}

model IngredientCategory {
  id   String @id @default(cuid())
  name String
  slug String @unique

  ingredients Ingredient[]

  @@map("ingredient_categories")
}

model Tag {
  id   String @id @default(cuid())
  name String
  slug String @unique

  recipes RecipeTag[]

  @@map("tags")
}

// ─── Recipe structure ─────────────────────────────────────────────────────────

model IngredientGroup {
  id        String @id @default(cuid())
  recipeId  String
  name      String
  sortOrder Int    @default(0)

  recipe      Recipe             @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredients RecipeIngredient[]

  @@map("ingredient_groups")
}

// ─── Core models ──────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  avatarUrl String?
  password  String?

  peopleCount    Int                @default(2)
  mealsPerWeek   Int                @default(5)
  cookTime       CookTimePreference @default(any)
  goal           FoodGoal           @default(healthy)
  dislikes       String[]
  onboardingDone Boolean            @default(false)
  isAdmin        Boolean            @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  weeklyPlans   WeeklyPlan[]
  favorites     FavoriteRecipe[]
  refreshTokens RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

model Ingredient {
  id         String              @id @default(cuid())
  name       String              @unique
  categoryId String?
  category   IngredientCategory? @relation(fields: [categoryId], references: [id])

  recipeIngredients RecipeIngredient[]
  groceryListItems  GroceryListItem[]
  aliases           IngredientAlias[]

  @@map("ingredients")
}

model IngredientAlias {
  id           String     @id @default(cuid())
  alias        String     @unique // normalized: lowercase + trim
  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@map("ingredient_aliases")
}

model Recipe {
  id              String  @id @default(cuid())
  title           String
  description     String
  cookTimeMinutes Int
  servings        Int     @default(2)
  imageUrl        String?
  sourceUrl       String? @unique
  steps           Json
  isActive        Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ingredients RecipeIngredient[]
  groups      IngredientGroup[]
  tags        RecipeTag[]
  planMeals   WeeklyPlanMeal[]
  favorites   FavoriteRecipe[]
  groceryItemSources GroceryListItemSource[]

  @@map("recipes")
}

model RecipeTag {
  recipeId String
  tagId    String

  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId],    references: [id])

  @@id([recipeId, tagId])
  @@map("recipe_tags")
}

model RecipeIngredient {
  id           String  @id @default(cuid())
  recipeId     String
  ingredientId String
  groupId      String?
  unitId       String?
  amount       Float

  recipe     Recipe           @relation(fields: [recipeId],     references: [id], onDelete: Cascade)
  ingredient Ingredient       @relation(fields: [ingredientId], references: [id])
  group      IngredientGroup? @relation(fields: [groupId],      references: [id])
  unit       Unit?            @relation(fields: [unitId],       references: [id])

  @@index([recipeId])
  @@map("recipe_ingredients")
}

model WeeklyPlan {
  id            String     @id @default(cuid())
  userId        String
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  weekStartDate DateTime
  status        PlanStatus @default(draft)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  meals       WeeklyPlanMeal[]
  groceryList GroceryList?

  @@index([userId])
  @@index([userId, weekStartDate])
  @@map("weekly_plans")
}

model WeeklyPlanMeal {
  id           String     @id @default(cuid())
  weeklyPlanId String
  weeklyPlan   WeeklyPlan @relation(fields: [weeklyPlanId], references: [id], onDelete: Cascade)
  recipeId     String
  recipe       Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  day          DayOfWeek
  isLocked     Boolean    @default(false)

  @@unique([weeklyPlanId, day])
  @@map("weekly_plan_meals")
}

model GroceryList {
  id           String     @id @default(cuid())
  weeklyPlanId String     @unique
  weeklyPlan   WeeklyPlan @relation(fields: [weeklyPlanId], references: [id], onDelete: Cascade)
  generatedAt  DateTime   @default(now())

  items GroceryListItem[]

  @@map("grocery_lists")
}

model GroceryListItem {
  id            String      @id @default(cuid())
  groceryListId String
  ingredientId  String
  unitId        String?
  totalAmount   Float
  isChecked     Boolean     @default(false)

  groceryList GroceryList            @relation(fields: [groceryListId], references: [id], onDelete: Cascade)
  ingredient  Ingredient             @relation(fields: [ingredientId], references: [id])
  unit        Unit?                  @relation(fields: [unitId],       references: [id])
  sources     GroceryListItemSource[]

  @@map("grocery_list_items")
}

model GroceryListItemSource {
  id                String    @id @default(cuid())
  groceryListItemId String
  recipeId          String
  day               DayOfWeek
  amount            Float     @default(0)
  unitId            String?

  groceryListItem GroceryListItem @relation(fields: [groceryListItemId], references: [id], onDelete: Cascade)
  recipe          Recipe          @relation(fields: [recipeId],          references: [id], onDelete: Cascade)
  unit            Unit?           @relation(fields: [unitId],            references: [id])

  @@map("grocery_list_item_sources")
}

model FavoriteRecipe {
  userId   String
  recipeId String
  savedAt  DateTime @default(now())

  user   User   @relation(fields: [userId],   references: [id], onDelete: Cascade)
  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@id([userId, recipeId])
  @@map("favorite_recipes")
}
