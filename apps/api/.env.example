DATABASE_URL="postgresql://mealy:mealy@localhost:5432/mealy"
REDIS_URL="redis://localhost:6379"

# Shared secret with NextAuth — must match AUTH_SECRET in apps/web/.env.local
AUTH_SECRET="change-me-auth-secret-min-32-chars"

# Optional: protect /auth/upsert-oauth-user from public access
INTERNAL_API_KEY=""

# App
PORT=3001
FRONTEND_URL="http://localhost:3000"

# Scraper
SCRAPER_API_KEY="change-me-scraper-api-key"
